# Keep the image lean and never ship the raw game binary or dev artifacts.
.git
.gitignore
**/__pycache__
**/*.pyc
*.egg-info
.pytest_cache
.venv
venv

# node / build outputs (the SPA is rebuilt inside the image)
node_modules
web/node_modules
web/dist
nightreign/ui/static/app

# local-only working copies — NEVER ship (regulation.bin is the game binary,
# NR0000.sl2 is a personal save)
inputs/

# not needed at runtime
tests/
experiments/
examples/
